<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
	</PropertyGroup>

	<ItemGroup>
		<Compile Include="Initialization\AccessTokenRetriever.fs" />
		<Compile Include="Initialization\SiloHostBuilder.fs" />
		<Compile Include="Initialization\SiloClientBuilder.fs" />
		<Compile Include="Initialization\TestData.fs" />
		<Compile Include="Initialization\AccessTokenProvider.fs" />
		<Compile Include="Initialization\RootConfiguration.fs" />
		<Compile Include="Connection\ConnectionTests.fs" />
		<Compile Include="Connection\DiscoveryDocumentProviderTests.fs" />
		<Compile Include="AccessToken\AccessTokenVerificationTests.fs" />
		<Compile Include="Authorization\SimpleAuthorizationTests.fs" />
		<Compile Include="Authorization\RoleBasedAuthorizationTests.fs" />
		<Compile Include="Authorization\ClaimsBasedAuthorizationTests.fs" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Identity.Client" Version="4.84.1" />
		<PackageReference Include="xunit" Version="2.9.3" />
	</ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Microsoft.Orleans.Client" Version="8.2.*" />
    <PackageReference Include="Microsoft.Orleans.Server" Version="8.2.*" />
    <PackageReference Include="Microsoft.Orleans.Sdk"     Version="8.2.*" />
    <PackageReference Include="Microsoft.Orleans.Runtime" Version="8.2.*" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <PackageReference Include="Microsoft.Orleans.Client" Version="9.2.*" />
    <PackageReference Include="Microsoft.Orleans.Server" Version="9.2.*" />
    <PackageReference Include="Microsoft.Orleans.Sdk"     Version="9.2.*" />
    <PackageReference Include="Microsoft.Orleans.Runtime" Version="9.2.*" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Microsoft.Orleans.Client" Version="10.1.*" />
    <PackageReference Include="Microsoft.Orleans.Server" Version="10.1.*" />
    <PackageReference Include="Microsoft.Orleans.Sdk"     Version="10.1.*" />
    <PackageReference Include="Microsoft.Orleans.Runtime" Version="10.1.*" />
  </ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\..\..\deploy\MicrosoftEntra\Configuration\AuthZI.Deploy.MicrosoftEntra.Configuration.fsproj" />
		<ProjectReference Include="..\..\..\..\src\AuthZI.Extensions\AuthZI.Extensions.fsproj" />
		<ProjectReference Include="..\..\..\..\src\AuthZI.MicrosoftOrleans\AuthZI.MicrosoftOrleans.fsproj" />
		<ProjectReference Include="..\..\..\..\src\AuthZI.MicrosoftOrleans.MicrosoftEntra\AuthZI.MicrosoftOrleans.MicrosoftEntra.fsproj" />
		<ProjectReference Include="..\..\..\AuthZI.Tests.Common.Xunit\AuthZI.Tests.Common.Xunit.csproj" />
		<ProjectReference Include="..\..\Grains\AuthZI.Tests.MicrosoftOrleans.Grains.csproj" />
	</ItemGroup>

</Project>